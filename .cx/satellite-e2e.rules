cmd/satellite_repos_pull.go
cmd/satellite_mirror.go
cmd/satellite_worktree.go
cmd/satellite_state.go
cmd/satellite_upgrade.go
cmd/internal/worktree_path.go
tests/scenarios_satellite.go
tests/satellite_endpoint.go
tests/satellite_sim.go
tests/satellite_real.go
cmd/satellite_config.go
cmd/satellite.go
